{
  "name": "@big-calendar/source",
  "version": "0.0.0",
  "private": true,
  "description": "Big Calendar — framework-agnostic calendar engine with thin per-framework UI packages.",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@11.1.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "nx run-many -t build",
    "test": "nx run-many -t test",
    "lint": "nx run-many -t lint",
    "typecheck": "nx run-many -t typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "playwright": "playwright test --config playwright/playwright.config.js",
    "playwright:update": "playwright test --config playwright/playwright.config.js --update-snapshots",
    "affected:build": "nx affected -t build",
    "affected:test": "nx affected -t test",
    "affected:lint": "nx affected -t lint",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@eslint/js": "^10.0.1",
    "@nx/eslint-plugin": "^22.7.5",
    "@playwright/test": "^1.61.1",
    "@storybook/addon-docs": "10.4.6",
    "@storybook/addon-links": "10.4.6",
    "@storybook/angular": "10.4.6",
    "@storybook/react-vite": "10.4.6",
    "@storybook/vue3-vite": "10.4.6",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jiti": "^2.7.0",
    "nx": "^22.7.5",
    "prettier": "^3.8.3",
    "storybook": "10.4.6",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1",
    "vite": "^8.0.16",
    "vite-plugin-dts": "^5.0.2",
    "vitest": "^4.1.8",
    "vue-tsc": "^3.3.5"
  }
}
