{
  "name": "localizer",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "packages/localizer/src",
  "tags": ["scope:localizer"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": { "command": "vite build", "cwd": "packages/localizer" }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": { "command": "vitest run", "cwd": "packages/localizer" }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": { "command": "eslint packages/localizer/src" }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc --noEmit -p packages/localizer/tsconfig.json"
      }
    }
  }
}
