{
  "name": "@big-calendar/lit",
  "version": "0.1.0",
  "type": "module",
  "description": "Big Calendar — @big-calendar/lit",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bigcalendar/big-calendar.git",
    "directory": "packages/lit"
  },
  "sideEffects": false,
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./*": {
      "import": "./dist/*/index.js",
      "types": "./dist/*/index.d.ts",
      "default": "./dist/*/index.js"
    }
  },
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@big-calendar/core": "workspace:*",
    "@big-calendar/styles": "workspace:*",
    "@lit/context": "^1.1.3",
    "@preact/signals-core": "^1.14.2",
    "clsx": "^2.1.1",
    "lit": "^3.2.0"
  },
  "peerDependencies": {
    "@big-calendar/dnd": "workspace:*",
    "lit": ">=3.0"
  },
  "peerDependenciesMeta": {
    "@big-calendar/dnd": {
      "optional": true
    }
  },
  "devDependencies": {
    "@big-calendar/dnd": "workspace:*",
    "@big-calendar/localizer-luxon": "workspace:*",
    "@big-calendar/localizer-temporal": "workspace:*",
    "jsdom": "^29.1.1"
  }
}
