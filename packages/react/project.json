{
  "name": "react",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "packages/react/src",
  "tags": ["scope:ui"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": { "command": "vite build", "cwd": "packages/react" }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": { "command": "vitest run", "cwd": "packages/react" }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": { "command": "eslint packages/react/src" }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": { "command": "tsc --noEmit -p packages/react/tsconfig.json" }
    },
    "storybook": {
      "executor": "nx:run-commands",
      "options": { "command": "storybook dev -p 6006 --no-open", "cwd": "packages/react" }
    },
    "build-storybook": {
      "executor": "nx:run-commands",
      "options": { "command": "storybook build", "cwd": "packages/react" }
    }
  }
}
