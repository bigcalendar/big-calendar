{
  "name": "dnd",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "packages/dnd/src",
  "tags": ["scope:dnd"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": { "command": "vite build", "cwd": "packages/dnd" }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": { "command": "vitest run", "cwd": "packages/dnd" }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": { "command": "eslint packages/dnd/src" }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": { "command": "tsc --noEmit -p packages/dnd/tsconfig.json" }
    }
  }
}
