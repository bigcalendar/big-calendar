{
  "name": "@big-calendar/core",
  "version": "0.1.0",
  "type": "module",
  "description": "Big Calendar — @big-calendar/core",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bigcalendar/big-calendar.git",
    "directory": "packages/core"
  },
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./utils": {
      "types": "./dist/utils/index.d.ts",
      "import": "./dist/utils.js"
    }
  },
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "typesVersions": {
    "*": {
      "utils": [
        "./dist/utils/index.d.ts"
      ]
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@big-calendar/localizer": "workspace:*",
    "@floating-ui/core": "^1.7.5",
    "@preact/signals-core": "^1.14.2"
  },
  "devDependencies": {
    "@big-calendar/localizer-luxon": "workspace:*",
    "@big-calendar/localizer-temporal": "workspace:*",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  }
}
