{
  "name": "core",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "packages/core/src",
  "tags": ["scope:core"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": { "command": "vite build", "cwd": "packages/core" }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": { "command": "vitest run", "cwd": "packages/core" }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": { "command": "eslint packages/core/src" }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": { "command": "tsc --noEmit -p packages/core/tsconfig.json" }
    }
  }
}
