{
  "name": "svelte",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "packages/svelte/src",
  "tags": ["scope:ui"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": { "command": "vite build", "cwd": "packages/svelte" }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": { "command": "vitest run", "cwd": "packages/svelte" }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": { "command": "eslint packages/svelte/src" }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": { "command": "svelte-check --tsconfig tsconfig.json", "cwd": "packages/svelte" }
    },
    "storybook": {
      "executor": "nx:run-commands",
      "options": { "command": "storybook dev -p 6011", "cwd": "packages/svelte" }
    },
    "build-storybook": {
      "executor": "nx:run-commands",
      "options": { "command": "storybook build", "cwd": "packages/svelte" }
    }
  }
}
