{
  "name": "localizer-temporal",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "packages/localizer-temporal/src",
  "tags": ["scope:localizer"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vite build",
        "cwd": "packages/localizer-temporal"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vitest run",
        "cwd": "packages/localizer-temporal"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": { "command": "eslint packages/localizer-temporal/src" }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc --noEmit -p packages/localizer-temporal/tsconfig.json"
      }
    }
  }
}
